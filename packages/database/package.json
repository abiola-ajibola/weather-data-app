{
  "name": "@weather-data-app/database",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "build": "yarn prisma:generate && tsc -p tsconfig.json",
    "start": "node -e \"console.log('Database workspace has no runtime server')\""
  },
  "dependencies": {
    "@prisma/client": "^6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6",
    "typescript": "^6.0.3"
  }
}
